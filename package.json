{
  "name": "float-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/praison-j/FloatAI.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "compile-electron": "tsc --project tsconfig.electron.json && node scripts/fix-electron-extensions.mjs",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && npm run compile-electron && electron .\"",
    "electron-pack": "npm run build && npm run compile-electron && electron-builder",
    "electron-pack-fallback": "npm run build && npm run compile-electron && electron-packager . FloatAI --platform=win32 --arch=x64 --overwrite --out=release --prune=true --ignore=\"^/(src|electron|\\.github|\\.git|terminals|agent-transcripts)/\""
  },
  "dependencies": {
    "electron-is-dev": "^3.0.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.1.2",
    "electron": "^34.3.0",
    "electron-builder": "^24.13.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.float.ai",
    "productName": "FloatAI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "praison-j",
        "repo": "FloatAI"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    }
  }
}
